# ─── Server ─────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development
CLIENT_ORIGIN=http://localhost:5173

# ─── Database (Supabase pooled connection) ──────────────────────────────────
# Replace [YOUR-PASSWORD] with your actual Supabase database password.
DATABASE_SSL=true
# NOTE: the "@" in the password MUST be URL-encoded as "%40" inside a
# connection string, otherwise pg parses it as the host separator.
DATABASE_URL=postgresql://postgres.lmjaejvtyghwvmtwdakg:9640082321%40VENKI@aws-1-ap-northeast-1.pooler.supabase.com:6543/postgres


# ─── JWT (dev secrets — regenerate in prod: openssl rand -base64 48) ────────
JWT_ACCESS_SECRET=WYUcCbV78uQpAWnxjJQYvTFZaI7ucw5DUH3FIzM8etL/Ex9EMbcSoPB2jAjnmOYv
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=BQeEjwct7BlVmNhn11ttKRcgJb+seOcb/UZfiphZHk8elenllam0yzFjO8MQnK5Q
JWT_REFRESH_EXPIRES_IN=30d
BCRYPT_SALT_ROUNDS=10

# ─── Trial / Subscription ───────────────────────────────────────────────────
TRIAL_DAYS=15
REFERRAL_REWARD_DAYS=15
SUBSCRIPTION_CURRENCY=INR

# Prices in paise (1 INR = 100 paise). Durations are fixed: 30 / 90 / 365 days.
SUBSCRIPTION_PRICE_MONTHLY_PAISE=49900
SUBSCRIPTION_PRICE_QUARTERLY_PAISE=219900
SUBSCRIPTION_PRICE_YEARLY_PAISE=699900

# One-time ₹1 anti-spam verification (user pays this before they can download).
VERIFICATION_PRICE_PAISE=100

